@model LoginViewModel
@{
    ViewData["Title"] = "Login";
}

<section class="card" style="max-width: 460px; margin: 0 auto;">
    <h1 class="hero-title" style="font-size: 1.85rem;">Welcome back</h1>
    <p class="hero-subtitle">Sign in to continue to your authenticated workspace.</p>

    <form asp-action="Login" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

        <div asp-validation-summary="ModelOnly"></div>

        <div class="form-row">
            <label asp-for="Username"></label>
            <input asp-for="Username" autocomplete="username" />
            <span asp-validation-for="Username"></span>
        </div>

        <div class="form-row">
            <label asp-for="Password"></label>
            <input asp-for="Password" autocomplete="current-password" />
            <span asp-validation-for="Password"></span>
        </div>

        <div class="form-row">
            <label>
                <input asp-for="RememberMe" /> Remember me
            </label>
        </div>

        <button class="btn btn-primary" type="submit">Sign in</button>
    </form>

    <p class="hero-subtitle" style="margin-top: 1rem;"><strong>Demo credentials:</strong> admin / Pass@123</p>
</section>
