<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cookie Auth MVC</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="topbar">
        <nav class="nav">
            <div class="nav-links">
                <a class="brand" asp-controller="Home" asp-action="Index">Minimal Auth App</a>
            </div>

            <div class="nav-user">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <span class="chip">@User.Identity.Name</span>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-subtle" type="submit">Logout</button>
                    </form>
                }
                else
                {
                    <a class="btn btn-primary" asp-controller="Account" asp-action="Login">Login</a>
                }
            </div>
        </nav>
    </header>

    <main class="page" role="main">
        @RenderBody()
    </main>
</body>
</html>
